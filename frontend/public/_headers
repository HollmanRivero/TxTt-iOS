# Cloudflare Pages headers
# Tving alltid revalidering av service worker + app-shell, slik at nye
# deploys plukkes opp uten cache-rens/inkognito. Hashede assets (immutable)
# caches fortsatt lenge som standard.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate
/registerSW.js
  Cache-Control: public, max-age=0, must-revalidate
